# syntax=docker/dockerfile:1
# Dev image: mounts source via volume, runs `next dev` for hot reload

FROM node:24-alpine
WORKDIR /app

ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1

# Install deps once; they're cached unless package.json changes
COPY package.json package-lock.json ./
RUN npm install --ignore-scripts

EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

CMD ["npm", "run", "dev"]
